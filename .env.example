# WP Block Theme Generator - Environment Variables
#
# For local development: No env vars are required.
# Users enter their provider + API key directly in the UI.
#
# For deployed version (Vercel): Set the key for the default provider.
# Users visiting the site can use this key or enter their own.

# Default AI provider key (used when "Use server-configured key" is checked)
# Supports: OpenRouter, Anthropic, OpenAI, Grok
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROK_API_KEY=

# Langfuse observability (optional — for tracing AI calls)
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
